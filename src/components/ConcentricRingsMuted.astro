---
/* Static op-art motif: concentric circles with an accent-color center dot.
   Muted variant for the production homepage — thinner strokes and lower
   opacity than the Signal prototype's ConcentricRings, per the "make it
   more muted" direction. Decorative — aria-hidden. Uses currentColor for
   rings so it inherits ink, and the graphic accent token for the center dot
   (the only above-the-fold use of the accent color). */
---

<svg
  class="motif-rings-muted"
  viewBox="0 0 300 300"
  role="presentation"
  aria-hidden="true"
  focusable="false"
>
  <g fill="none" stroke="currentColor" stroke-width="1" opacity="0.55">
    <circle cx="150" cy="150" r="140" />
    <circle cx="150" cy="150" r="115" />
    <circle cx="150" cy="150" r="90" />
    <circle cx="150" cy="150" r="65" />
    <circle cx="150" cy="150" r="40" />
  </g>
  <circle cx="150" cy="150" r="14" fill="var(--color-accent-graphic)" />
</svg>

<style>
  .motif-rings-muted {
    width: 100%;
    height: auto;
    color: var(--color-ink);
  }
</style>
