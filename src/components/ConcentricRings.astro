---
/* Static op-art motif: concentric circles with an accent-color center dot.
   Decorative — aria-hidden. Uses currentColor for rings so it inherits ink,
   and the graphic accent token for the center dot. */
---

<svg
  class="motif-rings"
  viewBox="0 0 300 300"
  role="presentation"
  aria-hidden="true"
  focusable="false"
>
  <g fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="150" cy="150" r="140" />
    <circle cx="150" cy="150" r="115" />
    <circle cx="150" cy="150" r="90" />
    <circle cx="150" cy="150" r="65" />
    <circle cx="150" cy="150" r="40" />
  </g>
  <circle cx="150" cy="150" r="18" fill="var(--color-accent-graphic)" />
</svg>

<style>
  .motif-rings {
    width: 100%;
    height: auto;
    color: var(--color-ink);
  }
</style>
