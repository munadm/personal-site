---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Base
  title="Writing: Munad Mahinoor"
  description="Essays on engineering leadership and building with AI agents, published on the blog."
>
  <SiteHeader slot="header" currentPath="/writing" />

  <section class="page-intro">
    <div class="container">
      <h1>Writing</h1>
      <p class="page-intro__lede">
        Essays live on the blog, at
        {' '}<a href="https://blog.munadmahinoor.com">blog.munadmahinoor.com</a>.
        Each essay is listed here as it goes live.
      </p>
    </div>
  </section>

  <hr class="divider-stripe divider-stripe--muted container-hr" />

  <section class="published">
    <div class="container">
      <h2>Essays</h2>
      <ul class="essay-list">
        <li class="essay">
          <p class="kicker">Essay</p>
          <h3>
            <a href="https://blog.munadmahinoor.com/agent-workforce/">
              How I built this site with an agent workforce
            </a>
          </h3>
          <p>
            Directing coding agents like ramping a new direct report. The bar flows
            from you to the agent, not the other way around.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <SiteFooter slot="footer" />
</Base>

<style>
  .page-intro {
    padding-block: var(--space-5) var(--space-3);
  }
  .page-intro__lede {
    font-size: var(--fs-subhead);
    line-height: var(--leading-heading);
    color: var(--color-muted);
    max-width: 60ch;
  }

  .container-hr {
    max-width: var(--container);
    margin-inline: auto;
    margin-block: var(--space-3);
  }

  .published {
    padding-block: var(--space-2) var(--space-7);
  }

  .essay-list {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
  }
  .essay {
    border: var(--border-hair) solid var(--color-rule-faint);
    padding: var(--space-3);
    max-width: 44rem;
  }
  .essay h3 a {
    color: var(--color-ink);
  }
  .essay p:last-child {
    margin-bottom: 0;
  }
</style>
