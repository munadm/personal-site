---
import Base from '../../layouts/Base.astro';
import RuleLogo from '../../components/RuleLogo.astro';

const entries = [
  {
    title: 'Scaling BNPL to $40B volume',
    kind: 'Case study',
  },
  {
    title: 'Innersource: the KCS API story',
    kind: 'Case study',
  },
  {
    title: 'How I built this site with an agent workforce',
    kind: 'Essay',
  },
];
---

<Base
  title="Munad Mahinoor — Senior Engineering Manager (Ledger prototype)"
  description="I build engineering orgs that ship with AI, from anywhere."
  personSchema
>
  <header slot="header" class="site-header">
    <div class="container site-header__inner">
      <a class="brand" href="/proto/ledger">
        <RuleLogo />
        <span class="brand__name">M. Mahinoor</span>
      </a>
    </div>
  </header>

  <section class="statement">
    <div class="container">
      <p class="kicker">Senior Engineering Manager — Payments</p>
      <h1>I build engineering orgs that ship with AI, from anywhere.</h1>
    </div>
  </section>

  <section class="toc" aria-labelledby="toc-heading">
    <div class="container">
      <h2 id="toc-heading" class="visually-hidden">Selected writing and case studies</h2>
      <ul class="toc-list">
        {
          entries.map((e) => (
            <li class="toc-row">
              <a class="toc-link" href="#">
                <span class="toc-title">{e.title}</span>
                <span class="toc-kind">{e.kind}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <div class="container">
    <hr class="divider-rules" />
  </div>

  <footer slot="footer" class="site-footer">
    <div class="container">
      <p class="footer-note">Ledger prototype — one of two directions. <a href="/">Back to chooser</a></p>
    </div>
  </footer>
</Base>

<style>
  .site-header {
    border-bottom: var(--border-bold) solid var(--color-rule);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    padding-block: var(--space-2);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-ink);
    text-decoration: none;
    font-weight: var(--fw-bold);
  }
  .brand__name {
    font-size: var(--fs-16);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .statement {
    padding-block: var(--space-6) var(--space-5);
  }
  .statement h1 {
    max-width: 20ch;
    margin-top: var(--space-2);
  }
  @media (min-width: 52rem) {
    .statement h1 {
      font-size: var(--fs-72);
    }
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: var(--border-hair) solid var(--color-rule);
  }
  .toc-row {
    border-bottom: var(--border-hair) solid var(--color-rule);
  }
  .toc-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    color: var(--color-ink);
    text-decoration: none;
  }
  .toc-title {
    font-size: var(--fs-24);
    font-weight: var(--fw-medium);
    letter-spacing: var(--tracking-tight);
  }
  .toc-kind {
    flex: none;
    font-size: var(--fs-14);
    font-weight: var(--fw-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .toc-link:hover {
    color: var(--color-accent);
  }
  .toc-link:hover .toc-title {
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-thickness: 2px;
  }
  .toc-link:hover .toc-kind {
    color: var(--color-accent);
  }

  .site-footer {
    padding-block: var(--space-3) var(--space-5);
  }
  .footer-note {
    font-size: var(--fs-14);
    color: var(--color-muted);
    margin: 0;
  }
</style>
