---
import Base from '../layouts/Base.astro';
import HeroRules from '../components/HeroRules.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const caseStudies = [
  {
    label: 'Case study 01',
    title: 'BNPL at $40B scale',
    blurb:
      'Leading the engineering org behind a Buy-Now-Pay-Later platform processing tens of billions in annual volume — reliability, risk, and velocity.',
    href: '/work',
  },
  {
    label: 'Case study 02',
    title: 'LLM PII scanner',
    blurb:
      'Shipping an internal LLM-powered scanner that flags personally identifiable information across services before it leaks into logs.',
    href: '/work',
  },
  {
    label: 'Essay',
    title: 'How I built this site with an agent workforce',
    blurb:
      'A point-of-view essay on directing a small team of AI agents through design, build, and accessibility verification.',
    href: '/writing',
  },
];
---

<Base
  title="Munad Mahinoor — Engineering leader"
  description="Engineering leader for AI-enabled, remote-first teams. Payments at scale."
  personSchema
>
  <SiteHeader slot="header" currentPath="/" />

  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <h1>Munad Mahinoor</h1>
        <p class="hero__subhead">
          Engineering leader for AI-enabled, remote-first teams. Payments at scale.
        </p>
        <div class="hero__actions">
          <a class="btn" href="#work">Read the case studies <span aria-hidden="true">&rarr;</span></a>
          <a class="btn-secondary" href="/resume.pdf">Download resume (PDF)</a>
        </div>
      </div>
      <div class="hero__motif">
        <HeroRules />
      </div>
    </div>
  </section>

  <hr class="divider-stripe divider-stripe--muted container-hr" />

  <section id="work" class="work">
    <div class="container">
      <h2>Selected work</h2>
      <ul class="cards">
        {
          caseStudies.map((c) => (
            <li class="card">
              <a class="card__link" href={c.href}>
                <p class="kicker">{c.label}</p>
                <h3>{c.title}</h3>
                <p>{c.blurb}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <SiteFooter slot="footer" />
</Base>

<style>
  .hero {
    padding-block: var(--space-4);
    overflow: hidden;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    align-items: center;
  }
  .hero__subhead {
    font-size: var(--fs-subhead);
    line-height: var(--leading-heading);
    color: var(--color-muted);
    margin-bottom: var(--space-3);
    max-width: 34ch;
  }
  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .btn-secondary {
    font-size: var(--fs-16);
    font-weight: var(--fw-medium);
    color: var(--color-ink);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  .btn-secondary:hover {
    text-decoration-thickness: 2px;
  }
  /* Mobile: the motif is a substantial element, not an ornament. Width (and
     hence height — the SVG is square) is capped at 45vh so it scales with
     the phone: on a large phone (428x926) it grows until the hero's bottom
     boundary lands essentially at the fold, while on an iPhone SE (375x667)
     it shrinks so at least 80% of the motif's height stays above the fold.
     It may exceed the container width slightly on tall phones, bleeding
     into the horizontal padding (never past the viewport edge);
     tests/fold.spec.ts enforces both fold targets and no-horizontal-scroll. */
  .hero__motif {
    width: min(calc(100% + 2 * var(--space-3)), 45vh);
    justify-self: center;
    opacity: 0.9;
  }

  @media (min-width: 52rem) {
    .hero {
      padding-block: var(--space-7);
    }
    .hero__inner {
      grid-template-columns: 1.2fr 0.8fr;
      gap: var(--space-5);
    }
    .hero__subhead {
      margin-bottom: var(--space-4);
    }
    /* Bleed the motif off the right edge, at reduced weight. Reset the
       mobile width so desktop stays exactly as approved. */
    .hero__motif {
      justify-self: end;
      margin-right: calc(-1 * var(--space-6));
      width: auto;
      max-width: 380px;
    }
  }

  .container-hr {
    max-width: var(--container);
    margin-inline: auto;
    margin-block: var(--space-3);
  }

  @media (min-width: 52rem) {
    .container-hr {
      margin-block: var(--space-6);
    }
  }

  .cards {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
  }
  @media (min-width: 44rem) {
    .cards {
      grid-template-columns: 1fr 1fr;
    }
    .cards li:last-child {
      grid-column: 1 / -1;
    }
  }
  .card {
    border: var(--border-hair) solid var(--color-rule-faint);
    background: var(--color-bg);
  }
  .card__link {
    display: block;
    padding: var(--space-3);
    color: var(--color-ink);
    text-decoration: none;
  }
  .card:hover {
    border-color: var(--color-ink);
  }
  .card h3 {
    margin-top: var(--space-1);
  }
  .card:hover h3 {
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-thickness: 2px;
  }
  .card p:last-child {
    margin-bottom: 0;
    color: var(--color-muted);
  }
</style>
